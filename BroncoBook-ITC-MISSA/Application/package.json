{
	"name": "application",
	"version": "0.0.1",
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^25.6.0",
		"bun-types": "^1.3.12",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"vite": "^8.0.7"
	},
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"backend:dev": "python3 -m uvicorn app.main:app --host 127.0.0.1 --port 8000 --reload",
		"backend:embeddings": "python3 scripts/build_embeddings.py",
		"backend:index": "python3 -c \"from app.retriever import CorpusRetriever; r=CorpusRetriever('data/corpus'); print(r.index_corpus(force=False))\"",
		"test:frontend": "bun test",
		"test:backend": "python3 -m pytest",
		"test": "bun run check && python3 -m pytest",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"type": "module"
}
