LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.3
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

DATABASE_URL=./data/campus_agent.db
CORPUS_DIR=./data/corpus
MAX_TOOL_RESULTS=6
TOP_K_CHUNKS=8
SESSION_TTL_MINUTES=90

ENABLE_SEMANTIC_SEARCH=true
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=512
EMBEDDING_BATCH_SIZE=128
BUILD_EMBEDDINGS_ON_STARTUP=false
FORCE_REBUILD_EMBEDDINGS=false
FORCE_REINDEX_CORPUS=false

LEXICAL_SCORE_WEIGHT=0.65
EMBEDDING_SCORE_WEIGHT=0.35
RRF_K=60
MIN_RETRIEVAL_FINAL_SCORE=0.25
