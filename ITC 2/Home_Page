          <!-- Title -->
          <h1 class="header-title">
            Cal Poly Pomona<br class="hidden sm:block" />
            Campus Knowledge Assistant
          </h1>
        </div>
      </header>

      <!-- Yellow top border strip -->
      <div class="border-strip"></div>

      <!-- Main Content -->
      <main>
        <!-- Search Bar -->
        <form class="search-form">
          <input
            type="text"
            class="search-input"
            placeholder="Ask Anything."
            aria-label="Search for campus information"
          />
          <button type="submit" class="search-button" aria-label="Search">
            <svg class="search-icon" viewBox="0 0 35 33" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path
                d="M30.625 28.875L24.2812 22.8937M27.7083 15.125C27.7083 21.2001 22.485 26.125 16.0417 26.125C9.59834 26.125 4.375 21.2001 4.375 15.125C4.375 9.04987 9.59834 4.125 16.0417 4.125C22.485 4.125 27.7083 9.04987 27.7083 15.125Z"
                stroke="#1E1E1E"
                stroke-width="3.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          </button>
        </form>

        <!-- Topic Pills -->
        <div class="topics-container">
          <!-- Row 1 -->
          <div class="topics-row">
            <button class="topic-pill">Admissions</button>
            <button class="topic-pill">Financial Aid</button>
            <button class="topic-pill">Directory</button>
          </div>
          <!-- Row 2 -->
          <div class="topics-row">
            <button class="topic-pill uppercase">Academics</button>
            <button class="topic-pill">Dining</button>
          </div>
        </div>
      </main>

      <!-- Yellow bottom border strip -->
      <div class="border-strip"></div>
    </div>
